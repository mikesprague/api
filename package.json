{
  "name": "api",
  "description": "Some API endpoints",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nubx tsc",
    "clean": "nubx rimraf dist/ && nubx rimraf build/",
    "docs": "nubx rimraf docs/ && nub run typedoc",
    "declarations": "nubx rimraf types/ && nubx tsc --emitDeclarationOnly",
    "env:load": "nubx varlock load",
    "env:scan": "nubx varlock scan",
    "github-trending-repos": "nub ./src/github-trending-repos.ts",
    "format": "nubx oxfmt src --write",
    "format:check": "nubx oxfmt src --check",
    "lint": "nubx oxlint src",
    "national-day": "nub ./src/national-day.ts",
    "posttypecheck": "nub run declarations",
    "test": "nub run format:check && nub run lint && nub run typecheck",
    "typecheck": "nubx tsc --noEmit",
    "typedoc": "typedoc --out ./docs --entryPointStrategy expand ./src --excludeNotDocumented false --plugin typedoc-plugin-markdown --readme none",
    "typedoc-html": "typedoc --out ./dist/docs --entryPointStrategy expand ./src --excludeNotDocumented false --readme none"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "url": "https://github.com/mikesprague/api"
  },
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@12.0.1",
  "dependencies": {
    "crawlee": "3.17.0",
    "dayjs": "1.11.21",
    "varlock": "1.13.0"
  },
  "devDependencies": {
    "@nubjs/nub": "0.4.13",
    "@nubjs/types": "0.4.13",
    "@types/node": "26.1.1",
    "cz-git": "1.13.1",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "rimraf": "6.1.3",
    "typedoc": "0.28.20",
    "typedoc-plugin-markdown": "4.12.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "adm-zip": "0.6.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "26.5.0",
    "npm": "12.0.1"
  },
  "allowScripts": {
    "@nubjs/nub": true
  }
}
