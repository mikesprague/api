{
  "name": "api",
  "description": "Some API endpoints",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun x tsc",
    "clean": "bun x rimraf dist/ && bun x rimraf build/",
    "docs": "bun x rimraf docs/ && bun run typedoc",
    "declarations": "bun x rimraf types/ && bun x tsc --emitDeclarationOnly",
    "env:load": "bun x varlock load",
    "env:scan": "bun x varlock scan",
    "github-trending-repos": "bun x tsx ./src/github-trending-repos.ts",
    "format": "bun x oxfmt src --write",
    "format:check": "bun x oxfmt src --check",
    "lint": "bun x oxlint src",
    "national-day": "bun x tsx ./src/national-day.ts",
    "posttypecheck": "bun run declarations",
    "test": "bun run format:check && bun run lint && bun run typecheck",
    "typecheck": "bun x tsc --noEmit",
    "typedoc": "bun x typedoc --out ./docs --entryPointStrategy expand ./src --excludeNotDocumented false --plugin typedoc-plugin-markdown --readme none",
    "typedoc-html": "bun x typedoc --out ./dist/docs --entryPointStrategy expand ./src --excludeNotDocumented false --readme none"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "url": "https://github.com/mikesprague/api"
  },
  "engines": {
    "bun": ">= 1.3.x",
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "crawlee": "3.16.0",
    "dayjs": "1.11.20",
    "varlock": "1.2.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "bun": "1.3.14",
    "bun-types": "1.3.14",
    "cross-env": "10.1.0",
    "cz-git": "1.13.1",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "rimraf": "6.1.3",
    "tsx": "4.22.2",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "6.0.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "26.1.0",
    "npm": "11.14.1"
  }
}
