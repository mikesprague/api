{
  "name": "api",
  "description": "Some API endpoints",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun x tsc",
    "clean": "bun x rimraf dist/ && bun x rimraf build/",
    "docs": "bun x rimraf docs/ && npm run typedoc",
    "declarations": "bun x rimraf types/ && tsc --emitDeclarationOnly",
    "github-trending-repos": "TZ='America/New_York' bun x tsx ./src/github-trending-repos.ts",
    "national-day": "TZ='America/New_York' bun x tsx ./src/national-day.ts",
    "national-week": "TZ='America/New_York' bun x tsx ./src/national-week.ts",
    "national-month": "TZ='America/New_York' bun x tsx ./src/national-month.ts",
    "posttypecheck": "npm run declarations",
    "test": "echo \"No tests yet...\"",
    "typecheck": "bun x tsc --noEmit",
    "typedoc": "bun x typedoc --out ./docs --entryPointStrategy expand ./src --excludeNotDocumented false --plugin typedoc-plugin-markdown --readme none",
    "typedoc-html": "bun x typedoc --out ./dist/docs --entryPointStrategy expand ./src --excludeNotDocumented false --readme none"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "url": "https://github.com/mikesprague/api"
  },
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "cheerio": "1.2.0",
    "dayjs": "1.11.20",
    "got": "15.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/cheerio": "1.0.0",
    "@types/node": "25.5.1",
    "bun": "1.3.11",
    "cross-env": "10.1.0",
    "cz-git": "1.12.0",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typedoc": "0.28.18",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "6.0.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "25.8.1",
    "npm": "11.12.0"
  }
}
