{
  "compilerOptions": {
    "composite": true,
    "declarationDir": "types",
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "lib": ["es2022"],
    "module": "es2022",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "target": "es2022",
    "types": ["node", "bun-types"]
  },
  "include": ["./src/**/*.ts"],
  "exclude": [
    ".git",
    ".github",
    ".history",
    "dist",
    "docs",
    "node_modules",
    "types",
    "src/**/*.d.ts",
    "./**/scratch*.ts",
    "<node_internals>/**"
  ]
}
