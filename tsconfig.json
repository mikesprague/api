{
  "compilerOptions": {
    "strict": true,
    "experimentalDecorators": true,
    "strictNullChecks": true,
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strictFunctionTypes": true,
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node"],
    "lib": ["es2022"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "composite": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "<node_internals>/**",
    "node_modules",
    ".history",
    ".git",
    ".github",
    "./src/**/scratch*.ts",
    "./src/**/*.d.ts",
    "./types/*.d.ts",
    "./types/*.ts"
  ]
}

